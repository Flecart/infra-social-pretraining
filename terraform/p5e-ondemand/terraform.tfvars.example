# Copy to terraform.tfvars and edit.
aws_region      = "us-east-1"
aws_profile     = "emanuele"
public_key_path = "~/.ssh/id_ed25519.pub" # key for the default `ubuntu` admin user

# CIDR blocks allowed to SSH in. Fail-closed: empty = nobody. Use your own IP
# ("$(curl -s https://checkip.amazonaws.com)/32") and/or institution ranges.
allowed_ssh_cidrs = [
  "129.67.0.0/16", # Oxford
  "129.132.0.0/16", # ETH Zurich
  # ... see README for the full Oxford + ETH list
]

# Human users. Each gets a home on the persistent /home volume that survives
# every teardown. UIDs are PINNED — pick a unique one per user and never change
# it once that user has data. Add/remove users here, then `make up`.
users = [
  {
    name = "angelo"
    uid  = 1001
    sudo = true
    ssh_authorized_keys = [
      "ssh-ed25519 AAAA... angelo@laptop",
    ]
  },
  {
    name = "emanuele"
    uid  = 1002
    ssh_authorized_keys = [
      "ssh-ed25519 AAAA... emanuele@laptop",
    ]
  },
]

# REQUIRED for p5e: it cannot launch as plain on-demand. Purchase an EC2 Capacity
# Block for ML, then set its reservation id and flip capacity_block = true.
# For a standard On-Demand Capacity Reservation, set the id but leave capacity_block = false.
# capacity_reservation_id = "cr-0123456789abcdef0"
# capacity_block          = true

running = true # set false to stop (keep data), or run `terraform destroy` to remove
